# =============================================================================
# SEPA Signals — Master Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#   chmod 600 .env          # keep credentials private
#
# On the mini PC the systemd service loads this via EnvironmentFile=.
# Locally: just having .env in the project root is enough (config.py auto-loads it).
# =============================================================================


# -----------------------------------------------------------------------------
# CREDENTIALS  (required for live operation)
# -----------------------------------------------------------------------------

# Anthropic API key — used by the AI validator (Phase 7).
# Get one at: console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token — create a bot via @BotFather on Telegram.
# Steps: open @BotFather → /newbot → follow prompts → copy the token here.
TELEGRAM_TOKEN=

# Your Telegram chat ID — send any message to your bot, then visit:
#   https://api.telegram.org/bot<TELEGRAM_TOKEN>/getUpdates
# and look for "chat": {"id": <number>}
TELEGRAM_CHAT_ID=


# -----------------------------------------------------------------------------
# AI VALIDATOR MODEL
# -----------------------------------------------------------------------------
# Which Claude model runs the final Buy Ready sanity-check.
# Haiku is recommended: fast, cheap, capable enough for a bounded judgment call.
# Bump to Sonnet if you want richer reasoning (more tokens, more cost).
#
#   claude-haiku-4-5-20251001    ← default, recommended
#   claude-sonnet-4-6            ← higher quality, ~5x cost
#   claude-opus-4-7              ← overkill for this task
VALIDATOR_MODEL=claude-haiku-4-5-20251001


# -----------------------------------------------------------------------------
# ACCOUNT & RISK
# -----------------------------------------------------------------------------
# These drive the position-sizing math on every alert card.
# The formula: shares = (ACCOUNT_SIZE × RISK_PER_TRADE) / (entry - stop)

# Your total trading account size in USD
ACCOUNT_SIZE=100000

# Max risk per trade as a decimal (0.0125 = 1.25%)
# Minervini typically uses 0.5–2% depending on conviction.
RISK_PER_TRADE=0.0125


# -----------------------------------------------------------------------------
# MARKET TONE GATE  (the "tape" third axis)
# -----------------------------------------------------------------------------
# This is a manual switch you update based on your own market read.
# The engine will NOT issue new Buy Ready alerts in a Correction.
# In "Under pressure", Buy Ready is downgraded to Buy Alert.
#
#   Confirmed uptrend   ← full signal; all three tiers active
#   Under pressure      ← conservative; no new Buy Ready (only Buy Alert)
#   Correction          ← defensive; no new buys at all
MARKET_TONE=Confirmed uptrend


# -----------------------------------------------------------------------------
# SEPA FUNDAMENTAL THRESHOLDS  (tune after Phase 2 calibration)
# -----------------------------------------------------------------------------
# These encode Minervini's "Accelerating Growth" criteria.
# A stock must pass FUND_MIN_SCORE of the 7 checks to enter the funnel.

# Minimum EPS year-over-year growth rate (compare Q to same Q prior year)
# Minervini: +20-50%+ for the best setups; 20% is the minimum floor
FUND_EPS_GROWTH_MIN=0.20

# Minimum sales YoY growth rate
FUND_SALES_GROWTH_MIN=0.20

# Operating margin floor — company must be meaningfully profitable
FUND_OP_MARGIN_MIN=0.10

# Return on Equity minimum (Minervini: >= 17%)
FUND_ROE_MIN=0.17

# How many of the 7 fundamental checks must pass (min 3 recommended; 4 for high conviction)
FUND_MIN_SCORE=3


# -----------------------------------------------------------------------------
# UNIVERSE & DATA
# -----------------------------------------------------------------------------
# SEC requires a real name + email in the User-Agent for EDGAR requests.
# Already set — only change if you want to use a different contact.
SEC_USER_AGENT=SEPA personal scanner lather10110@gmail.com

# How far back to pull price history via yfinance.
# "2y" covers enough history for VCP/stage detection across most bases.
PRICE_LOOKBACK=2y

# Cap the number of tickers ingested. Use a small number (e.g. 300) for
# initial calibration, then set to empty/none for the full universe.
# Empty = all SEC-listed tickers (~10,000+; use S&P 1500 list in Phase 2)
UNIVERSE_LIMIT=
