# Copy to /opt/sepa/.env and fill in your real credentials.
# This file must be readable only by the sepa user: chmod 600 /opt/sepa/.env

# Anthropic API key for the Phase 7 AI validator
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token (from @BotFather) and your chat ID
TELEGRAM_TOKEN=...
TELEGRAM_CHAT_ID=...
